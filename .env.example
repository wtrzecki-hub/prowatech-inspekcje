# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudflare R2 (storage zdjęć i protokołów)
# Uwaga: Account ID, Endpoint, Bucket, Public URL są hardkodowane w
# src/lib/storage/r2.ts (konwencja jak Supabase URL/anon key).
# Tu trzymamy tylko sekretne credentialsy.
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Skrypt migracji archiwum z Google Drive na R2:
# scripts/migrate_historical_protocols_from_gdrive.mjs
#
# Domyślnie skrypt używa LOKALNEGO napędu (Google Drive Stream zsynchronizowany
# jako napęd Windows, np. G:\). Service Account potrzebny tylko gdy chcesz przejść
# na ścieżkę API (--source=gdrive) — wymaga admin Workspace cgedata, więc dla
# Shared Drive w cgedata nie zadziała bez zmiany polityki.

# Tryb LOCAL (rekomendowany): ścieżka do folderu `21 Prowatech-inspekcje` na napędzie zsynchronizowanym.
# Może też być przekazane przez flagę `--local-path=...` przy uruchomieniu.
LOCAL_DRIVE_PATH=G:\Mój dysk\21 Prowatech-inspekcje

# Tryb GDRIVE (alternatywa, wymaga SA + udostępnionego folderu):
# Klucz JSON Service Account w .credentials/ (gitignored).
# Folder root ID — z URL Google Drive: https://drive.google.com/drive/folders/<ID>.
# GDRIVE_SA_KEY_PATH=.credentials/gdrive-sa.json
# GDRIVE_ROOT_FOLDER_ID=your_root_folder_id
